                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "feat_3",
                  "name": "Feature 3 Row",
                  "gap": 10,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "feat3_dot",
                      "name": "Dot",
                      "width": 6,
                      "height": 6,
                      "fill": "rgba(255, 255, 255, 0.50)",
