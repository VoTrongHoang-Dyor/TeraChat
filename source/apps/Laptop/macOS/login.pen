        {
          "type": "frame",
          "id": "right_login_panel",
          "name": "Right Login Panel",
          "x": 380,
          "y": 0,
          "width": 520,
          "height": 640,
          "fill": "#FFFFFF",
          "layout": "vertical",
          "gap": 32,
          "padding": 72,
          "justifyContent": "center",
          "children": [
            {
              "type": "frame",
              "id": "welcome_block",
