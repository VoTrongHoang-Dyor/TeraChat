{
  "version": "2.11",
  "children": [
    {
      "type": "frame",
      "id": "macOS_root",
      "x": 0,
      "y": 0,
      "name": "macOS Login Window",
      "clip": true,
      "width": 900,
      "height": 640,
      "fill": "#FFFFFF",
      "layout": "none",
      "children": [
        {
          "type": "frame",
          "id": "bg_decor",
          "name": "Background Decor Layer",
          "width": 900,
          "height": 640,
          "fill": "#F5F9FC",
          "children": [
            {
              "type": "ellipse",
              "id": "glow_top_right",
              "name": "Ambient Glow Top Right",
              "x": 520,
              "y": -120,
              "width": 500,
              "height": 400,
              "fill": "#E8F4FD",
              "opacity": 0.6
            },
            {
              "type": "ellipse",
              "id": "glow_bottom_left",
              "name": "Ambient Glow Bottom Left",
              "x": -100,
              "y": 380,
              "width": 400,
              "height": 300,
              "fill": "#D6EEFB",
              "opacity": 0.4
            }
          ]
        },
        {
          "type": "frame",
          "id": "left_brand_panel",
          "name": "Left Brand Panel",
          "x": 0,
          "y": 0,
          "width": 380,
          "height": 640,
          "fill": "#0F5B8A",
          "layout": "vertical",
          "gap": 28,
          "padding": 56,
          "justifyContent": "center",
          "children": [
            {
              "type": "frame",
              "id": "logo_container",
              "name": "Logo Frame",
              "width": 48,
              "height": 48,
              "fill": "rgba(255, 255, 255, 0.12)",
              "cornerRadius": 12,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "logo_letter",
                  "name": "Logo T",
                  "fill": "#FFFFFF",
                  "content": "T",
                  "fontFamily": "SF Pro Display",
                  "fontSize": 28,
                  "fontWeight": "800"
                }
              ]
            },
            {
              "type": "text",
              "id": "brand_name",
              "name": "Brand Name",
              "fill": "#FFFFFF",
              "content": "TeraChat",
              "fontFamily": "SF Pro Display",
              "fontSize": 36,
              "fontWeight": "800",
              "lineHeight": 1.1
            },
            {
              "type": "text",
              "id": "tagline",
              "name": "Tagline",
              "fill": "rgba(255, 255, 255, 0.70)",
              "content": "Enterprise Messaging Platform.\nZero-Knowledge.\nAbsolute Data Sovereignty.",
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "400",
              "lineHeight": 1.7
            },
            {
              "type": "frame",
              "id": "feature_list",
              "name": "Feature Highlights",
              "width": 280,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "feat_1",
                  "name": "Feature 1 Row",
                  "gap": 10,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "feat1_dot",
                      "name": "Dot",
                      "width": 6,
                      "height": 6,
                      "fill": "rgba(255, 255, 255, 0.50)",
                      "cornerRadius": 3
                    },
                    {
                      "type": "text",
                      "id": "feat1_text",
                      "name": "MLS E2EE",
                      "fill": "rgba(255, 255, 255, 0.70)",
                      "content": "MLS E2EE · Post-Quantum Ready",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "feat_2",
                  "name": "Feature 2 Row",
                  "gap": 10,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "feat2_dot",
                      "name": "Dot",
                      "width": 6,
                      "height": 6,
                      "fill": "rgba(255, 255, 255, 0.50)",
                      "cornerRadius": 3
                    },
                    {
                      "type": "text",
                      "id": "feat2_text",
                      "name": "Offline First",
                      "fill": "rgba(255, 255, 255, 0.70)",
