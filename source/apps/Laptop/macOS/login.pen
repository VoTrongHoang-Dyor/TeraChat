                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "security_badges",
              "name": "Security Badges Row",
              "gap": 12,
              "alignItems": "center",
